{
  "id": "rainbow-bot",
  "name": "彩虹机器人",
  "description": "大眼睛会随情绪变化的可爱机器人，身上有彩虹条纹",
  "dimensions": {
    "width": 90,
    "height": 120
  },
  "animations": {
