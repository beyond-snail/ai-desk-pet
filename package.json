{
  "name": "ai-desk-pet",
  "version": "1.0.0",
  "description": "AI 桌面宠物 - 你的智能桌面伙伴",
  "main": "runtime/godot/main.mjs",
  "scripts": {
    "start": "node scripts/start-runtime3d-release.mjs",
    "dev": "node scripts/start-runtime3d-release.mjs",
    "start:runtime3d": "node scripts/start-runtime3d-release.mjs",
    "start:runtime3d:bootstrap": "node scripts/start-runtime3d-bootstrap.mjs",
    "start:runtime3d:qt": "node runtime/qt-sidecar/main.mjs",
    "start:runtime3d:godot": "node runtime/godot/main.mjs",
    "smoke:runtime3d:ipc": "node scripts/runtime3d-ipc-smoke.mjs",
    "smoke:runtime3d:motion": "node scripts/runtime3d-robot-motion-smoke.mjs",
    "smoke:runtime3d:migration": "node scripts/runtime3d-migration-smoke.mjs",
    "smoke:runtime3d:backfill": "node scripts/runtime3d-backfill-smoke.mjs",
    "smoke:runtime3d:performance": "node scripts/runtime3d-performance-smoke.mjs",
    "build:runtime3d:package": "node scripts/package-runtime3d-candidate.mjs",
    "check:runtime3d:native": "node scripts/check-runtime3d-native.mjs",
    "check": "npm run check:syntax && npm run check:characters && npm run check:runtime3d",
    "check:syntax": "node scripts/check-syntax.mjs",
    "check:characters": "node scripts/verify-character-configs.mjs",
    "check:runtime3d": "node scripts/check-runtime3d.mjs",
    "build": "node scripts/build-runtime3d-release.mjs",
    "build:runtime3d": "node scripts/build-runtime3d-release.mjs",
    "build:runtime3d:release": "node scripts/build-runtime3d-release.mjs",
    "build:mac": "node scripts/build-runtime3d-release.mjs",
    "build:mac:local": "node scripts/build-runtime3d-release.mjs",
    "release:check:mac": "npm run check && npm run check:runtime3d:native",
    "build:mac:release": "npm run release:check:mac && npm run build:runtime3d:release",
    "release:check": "npm run release:check:mac",
    "build:win": "node scripts/build-runtime3d-release.mjs",
    "build:linux": "node scripts/build-runtime3d-release.mjs",
    "build:all": "node scripts/build-runtime3d-release.mjs",
    "build:dist": "npm run release:check && npm run build:runtime3d:release"
  },
  "keywords": [
    "godot",
    "qt6",
    "ai",
    "desktop-pet"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {},
  "devDependencies": {},
  "repository": {
    "type": "git",
    "url": "https://github.com/beyond-snail/ai-desk-pet.git"
  },
  "bugs": {
    "url": "https://github.com/beyond-snail/ai-desk-pet/issues"
  },
  "homepage": "https://github.com/beyond-snail/ai-desk-pet#readme"
}
